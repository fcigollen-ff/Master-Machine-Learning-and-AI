        "# A.4 — Tu código aquí\n",
        "def aplanar(lista: list) -> list:\n",
        "    \"\"\"Devuelve una lista plana con todos los elementos de una lista anidada.\"\"\"\n",
        "    resultado = []\n",
        "    for item in lista:\n",
        "        if isinstance(item, list):\n",
        "            resultado.extend(aplanar(item))\n",
        "        else:\n",
        "            resultado.append(item)\n",
        "    return resultado"
      ]
