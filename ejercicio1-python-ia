assert contar_vocales("AEIOU") == {"a": 1, "e": 1, "i": 1, "o": 1, "u": 1}, "Error: AEIOU"
assert contar_vocales("xyz") == {"a": 0, "e": 0, "i": 0, "o": 0, "u": 0}, "Error: sin vocales"
